<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>U.S. Department of the Treasury — SCRP</title>
<script>
// Simple no-op stubs so onclick= attributes don't throw ReferenceError during page parse.
// The ES module replaces each of these with real implementations on load.
var _noop=function(){};
['navigate','sotLogin','sotPanel','submitAccessRequest','processReq','reqTab',
 'toggleSuspend','toggleWatch','setBudget','penalizeBudget','grantBudget','resetBudget',
 'postAnnouncement','deleteAnn','toggleAnnPin','updateTicker','saveTaxRates',
 'addTaxRow','removeTax','savePrices','applyMult','toggleEmergency','liftMartialLaw',
 'confirmEmergency','issueSanction','removeSanction','renderAuditLog','clearAuditLog',
 'revokeUser','promoteUser','closeModal','selectDept','proceedToOrder','backToDept',
 'submitOrder','newOrder','addVehicleRow','checkVehFirst','addWeaponRow','checkFirstTimePurchase',
 'updateHeliDisplay','recalcAll','logout'
].forEach(function(n){ window[n]=_noop; });
</script>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=IBM+Plex+Mono:wght@300;400;500&family=EB+Garamond:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
:root{
  --navy:#0a1628;--navy-mid:#0f2040;--navy-light:#162c52;
  --gold:#c9a84c;--gold-light:#e8c97a;--gold-dim:#7a6230;
  --cream:#f5f0e8;--cream-dark:#e0d5bf;
  --red:#b02020;--green:#1a6b3a;--text-dim:#8899aa;
  --border:rgba(201,168,76,0.22);--sidebar-w:250px;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'EB Garamond',serif;background:#f2ede3;color:#1a1a2e;min-height:100vh;overflow-x:hidden;}
#app-shell{display:flex;min-height:100vh;}

/* SYNC INDICATOR */
#sync-indicator{
  position:fixed;bottom:18px;right:18px;z-index:9999;
  font-family:'IBM Plex Mono',monospace;font-size:0.6rem;
  letter-spacing:0.15em;padding:6px 12px;border-radius:2px;
  transition:all 0.4s;pointer-events:none;
}
#sync-indicator.synced{background:rgba(26,107,58,0.85);color:#88ffaa;border:1px solid rgba(26,107,58,0.5);}
#sync-indicator.syncing{background:rgba(201,168,76,0.85);color:#1a1a2e;border:1px solid rgba(201,168,76,0.5);}
#sync-indicator.error{background:rgba(176,32,32,0.85);color:#ffaaaa;border:1px solid rgba(176,32,32,0.5);}

/* TICKER */
#ticker{position:fixed;top:0;left:0;right:0;z-index:999;background:var(--navy);border-bottom:1px solid var(--border);height:28px;display:flex;align-items:center;overflow:hidden;}
#ticker-inner{display:flex;gap:60px;white-space:nowrap;animation:tickerScroll 40s linear infinite;font-family:'IBM Plex Mono',monospace;font-size:0.6rem;letter-spacing:0.1em;color:var(--gold-dim);}
#ticker-inner span{color:var(--gold);}
@keyframes tickerScroll{0%{transform:translateX(0);}100%{transform:translateX(-50%);}}

/* ALERT BANNER */
#alert-banner{display:none;position:fixed;top:28px;left:0;right:0;z-index:998;background:var(--red);padding:10px 20px;text-align:center;font-family:'IBM Plex Mono',monospace;font-size:0.72rem;letter-spacing:0.15em;color:#fff;border-bottom:2px solid #ff4444;animation:pulse-bg 2s infinite;}
@keyframes pulse-bg{0%,100%{background:var(--red);}50%{background:#8b1010;}}

/* MARTIAL LAW OVERLAY */
#martial-overlay{display:none;position:fixed;inset:0;z-index:9999;background:rgba(0,0,0,0.92);justify-content:center;align-items:center;flex-direction:column;text-align:center;}
#martial-overlay.active{display:flex;}
.martial-inner{border:2px solid var(--red);padding:60px 80px;max-width:700px;background:rgba(10,22,40,0.95);}
.martial-inner h1{font-family:'Playfair Display',serif;font-size:3rem;color:var(--red);margin-bottom:14px;letter-spacing:0.1em;animation:flicker 1.5s infinite;}
@keyframes flicker{0%,100%{opacity:1;}45%{opacity:0.7;}50%{opacity:1;}95%{opacity:0.8;}}
.martial-inner p{font-family:'IBM Plex Mono',monospace;font-size:0.8rem;color:#cc9999;line-height:2;letter-spacing:0.15em;}

/* SIDEBAR */
#sidebar{width:var(--sidebar-w);background:var(--navy);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:28px;left:0;bottom:0;z-index:200;transition:transform 0.3s ease;overflow-y:auto;}
#sidebar-logo{padding:22px 20px 16px;border-bottom:1px solid var(--border);text-align:center;}
#sidebar-logo .seal{font-size:34px;display:block;margin-bottom:8px;cursor:pointer;}
#sidebar-logo h2{font-family:'Playfair Display',serif;font-size:0.76rem;color:var(--gold);letter-spacing:0.06em;line-height:1.4;}
#sidebar-logo p{font-family:'IBM Plex Mono',monospace;font-size:0.52rem;color:var(--text-dim);letter-spacing:0.2em;text-transform:uppercase;margin-top:4px;}
#classif-badge{display:none;background:var(--red);color:#fff;font-family:'IBM Plex Mono',monospace;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;padding:3px 10px;border-radius:2px;margin-top:8px;text-align:center;}
nav{flex:1;padding:10px 0;}
.nav-section-label{font-family:'IBM Plex Mono',monospace;font-size:0.52rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--gold-dim);padding:12px 18px 5px;}
.nav-item{display:flex;align-items:center;gap:10px;padding:9px 18px;cursor:pointer;font-family:'IBM Plex Mono',monospace;font-size:0.7rem;color:#aabbcc;letter-spacing:0.04em;transition:all 0.15s;border-left:3px solid transparent;}
.nav-item:hover{color:var(--cream);background:rgba(201,168,76,0.06);border-left-color:var(--gold-dim);}
.nav-item.active{color:var(--gold);background:rgba(201,168,76,0.1);border-left-color:var(--gold);}
.nav-item .icon{font-size:13px;width:16px;text-align:center;}
.nav-item .badge-ct{margin-left:auto;background:var(--red);color:#fff;border-radius:10px;padding:1px 7px;font-size:0.55rem;}
.nav-divider{height:1px;background:var(--border);margin:8px 18px;}
#sidebar-footer{padding:14px 18px;border-top:1px solid var(--border);font-family:'IBM Plex Mono',monospace;font-size:0.58rem;color:var(--text-dim);text-align:center;line-height:1.6;}
#sidebar-footer .classified-label{color:var(--red);font-size:0.6rem;display:none;}
#clock{font-family:'IBM Plex Mono',monospace;font-size:0.68rem;color:var(--gold-dim);text-align:center;padding:6px 18px 0;}

/* MAIN */
#main-content{margin-left:var(--sidebar-w);flex:1;display:flex;flex-direction:column;min-height:100vh;padding-top:28px;}
#topbar{background:var(--navy);border-bottom:1px solid var(--border);padding:13px 36px;display:flex;align-items:center;gap:14px;position:sticky;top:28px;z-index:100;}
#topbar .topbar-title{font-family:'Playfair Display',serif;font-size:0.95rem;color:var(--gold);flex:1;}
.topbar-badge{font-family:'IBM Plex Mono',monospace;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;background:rgba(201,168,76,0.1);border:1px solid var(--border);padding:4px 10px;border-radius:2px;color:var(--gold);}
.topbar-badge.topsec{background:rgba(176,32,32,0.2);border-color:rgba(176,32,32,0.4);color:#ff9999;}
.btn-small{background:none;border:1px solid var(--border);color:var(--text-dim);padding:5px 11px;border-radius:2px;font-family:'IBM Plex Mono',monospace;font-size:0.6rem;cursor:pointer;letter-spacing:0.1em;text-transform:uppercase;transition:all 0.2s;}
.btn-small:hover{border-color:var(--gold-dim);color:var(--cream);}
.btn-small.danger{border-color:rgba(176,32,32,0.4);color:#cc6666;}
.btn-small.danger:hover{background:rgba(176,32,32,0.15);color:#ff9999;}

/* PAGE VIEWS */
.page-view{display:none;}
.page-view.active{display:block;}

/* ═══ PUBLIC HOME ═══ */
#page-home{background:#f2ede3;}
.hero-banner{background:var(--navy);color:var(--cream);padding:55px 55px 45px;position:relative;overflow:hidden;}
.hero-banner::before{content:'';position:absolute;inset:0;background:repeating-linear-gradient(0deg,transparent,transparent 60px,rgba(201,168,76,0.03) 60px,rgba(201,168,76,0.03) 61px),repeating-linear-gradient(90deg,transparent,transparent 60px,rgba(201,168,76,0.03) 60px,rgba(201,168,76,0.03) 61px);pointer-events:none;}
.hero-inner{position:relative;z-index:1;max-width:860px;}
.hero-eyebrow{font-family:'IBM Plex Mono',monospace;font-size:0.62rem;letter-spacing:0.3em;text-transform:uppercase;color:var(--gold-dim);margin-bottom:14px;}
.hero-banner h1{font-family:'Playfair Display',serif;font-size:clamp(1.8rem,3.5vw,2.8rem);color:var(--gold);line-height:1.15;margin-bottom:12px;}
.hero-banner p{font-size:1rem;color:#b8c8d8;line-height:1.75;max-width:660px;}
.hero-divider{width:90px;height:2px;background:linear-gradient(90deg,var(--gold),transparent);margin:20px 0;}
.home-grid{display:grid;grid-template-columns:1fr 330px;gap:36px;max-width:1400px;margin:0 auto;padding:36px 40px 60px;}
.tax-bulletin{background:var(--navy);color:var(--cream);border-radius:4px;border:1px solid var(--border);overflow:hidden;margin-bottom:26px;}
.tax-bulletin-header{background:rgba(201,168,76,0.1);border-bottom:1px solid var(--border);padding:14px 22px;display:flex;align-items:center;gap:12px;}
.tax-bulletin-header h3{font-family:'Playfair Display',serif;font-size:1rem;color:var(--gold);}
.tax-bulletin-header .eff{font-family:'IBM Plex Mono',monospace;font-size:0.6rem;color:var(--text-dim);margin-left:auto;letter-spacing:0.1em;}
.tax-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(150px,1fr));}
.tax-cell{padding:16px 18px;border-right:1px solid var(--border);border-bottom:1px solid var(--border);}
.tax-cell .tl{font-family:'IBM Plex Mono',monospace;font-size:0.56rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-dim);margin-bottom:5px;}
.tax-cell .tr{font-family:'Playfair Display',serif;font-size:1.5rem;color:var(--gold);}
.tax-cell .td{font-size:0.76rem;color:#8899aa;margin-top:2px;}
.section-header{display:flex;align-items:center;gap:12px;margin-bottom:18px;}
.section-header h2{font-family:'Playfair Display',serif;font-size:1.35rem;color:var(--navy);}
.section-header .line{flex:1;height:1px;background:linear-gradient(90deg,rgba(10,22,40,0.2),transparent);}
.ann-card{background:#fff;border:1px solid rgba(0,0,0,0.07);border-radius:3px;padding:18px 22px;margin-bottom:12px;border-left:4px solid var(--gold);box-shadow:0 2px 8px rgba(0,0,0,0.05);animation:fadeSlide 0.4s ease;}
.ann-card.urgent{border-left-color:var(--red);}
.ann-card.info{border-left-color:#2a6aad;}
.ann-meta{font-family:'IBM Plex Mono',monospace;font-size:0.6rem;color:#999;margin-bottom:7px;display:flex;align-items:center;gap:8px;flex-wrap:wrap;}
.ann-tag{padding:2px 7px;border-radius:2px;font-size:0.56rem;letter-spacing:0.15em;text-transform:uppercase;font-weight:500;}
.tag-official{background:#f0e8d0;color:#7a5c20;}
.tag-urgent{background:#fde8e8;color:#a02020;}
.tag-info{background:#e0eaf8;color:#1a4a8a;}
.ann-title{font-family:'Playfair Display',serif;font-size:1rem;color:var(--navy);margin-bottom:5px;}
.ann-body{font-size:0.88rem;color:#445;line-height:1.7;}
@keyframes fadeSlide{from{opacity:0;transform:translateY(5px);}to{opacity:1;transform:translateY(0);}}
.widget{background:#fff;border:1px solid rgba(0,0,0,0.07);border-radius:3px;margin-bottom:18px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.05);}
.widget-header{background:var(--navy);padding:13px 16px;border-bottom:1px solid var(--border);}
.widget-header h4{font-family:'Playfair Display',serif;font-size:0.9rem;color:var(--gold);}
.widget-body{padding:14px 16px;}
.br{display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid rgba(0,0,0,0.05);font-size:0.83rem;}
.br:last-child{border-bottom:none;}
.br .brl{color:#445;}
.br .brv{font-family:'IBM Plex Mono',monospace;font-size:0.76rem;color:var(--navy);font-weight:500;}
.ni{padding:11px 0;border-bottom:1px solid rgba(0,0,0,0.05);}
.ni:last-child{border-bottom:none;}
.ni .nid{font-family:'IBM Plex Mono',monospace;font-size:0.58rem;color:#aaa;margin-bottom:3px;}
.ni .nit{font-size:0.86rem;color:#1a1a2e;line-height:1.4;}
.public-footer{background:var(--navy);color:#8899aa;padding:28px 40px;margin-top:50px;border-top:1px solid var(--border);text-align:center;font-family:'IBM Plex Mono',monospace;font-size:0.67rem;line-height:1.8;letter-spacing:0.08em;}
.public-footer .endorsement{color:var(--gold);font-size:0.72rem;margin-bottom:7px;font-family:'Playfair Display',serif;font-style:italic;}

/* ═══ INTERIOR PAGES ═══ */
.page-hero{background:var(--navy);padding:38px 50px;border-bottom:1px solid var(--border);}
.page-hero h1{font-family:'Playfair Display',serif;font-size:1.75rem;color:var(--gold);margin-bottom:5px;}
.page-hero p{font-family:'IBM Plex Mono',monospace;font-size:0.67rem;color:var(--text-dim);letter-spacing:0.15em;text-transform:uppercase;}
.interior-page{background:#f2ede3;padding:44px 50px 70px;}
.content-card{background:#fff;border:1px solid rgba(0,0,0,0.07);border-radius:3px;padding:28px 34px;margin-bottom:22px;box-shadow:0 2px 8px rgba(0,0,0,0.05);}
.content-card h3{font-family:'Playfair Display',serif;font-size:1.1rem;color:var(--navy);border-bottom:1px solid rgba(0,0,0,0.07);padding-bottom:11px;margin-bottom:16px;}
.tbl{width:100%;border-collapse:collapse;font-size:0.88rem;}
.tbl th{text-align:left;padding:9px 10px;font-family:'IBM Plex Mono',monospace;font-size:0.6rem;letter-spacing:0.15em;text-transform:uppercase;color:#667;border-bottom:2px solid rgba(0,0,0,0.08);}
.tbl td{padding:11px 10px;border-bottom:1px solid rgba(0,0,0,0.05);color:#334;}
.tbl tr:hover td{background:rgba(201,168,76,0.04);}

/* ═══ DARK PAGES ═══ */
#page-login,#page-pending,#page-sot-login,#page-sot-dashboard,#page-user-portal{background:var(--navy);}
.dark-center{display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:calc(100vh - 90px);padding:40px 20px;}
.portal-header{text-align:center;margin-bottom:32px;}
.portal-seal{width:70px;height:70px;border:3px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28px;background:radial-gradient(circle,var(--navy-mid),var(--navy));box-shadow:0 0 24px rgba(201,168,76,0.3);margin:0 auto 16px;}
.portal-header h1{font-family:'Playfair Display',serif;font-size:1.55rem;color:var(--gold);margin-bottom:5px;}
.portal-header .sub{font-family:'IBM Plex Mono',monospace;font-size:0.63rem;color:var(--text-dim);letter-spacing:0.25em;text-transform:uppercase;}
.hdivider{width:170px;height:1px;background:linear-gradient(90deg,transparent,var(--gold),transparent);margin:13px auto;}
.dark-card{background:rgba(15,32,64,0.85);border:1px solid var(--border);border-radius:4px;padding:34px 38px;width:100%;max-width:500px;backdrop-filter:blur(10px);box-shadow:0 20px 60px rgba(0,0,0,0.5);}
.dark-card h2{font-family:'Playfair Display',serif;font-size:1.15rem;color:var(--gold);margin-bottom:3px;}
.dark-card .card-sub{font-family:'IBM Plex Mono',monospace;font-size:0.65rem;color:var(--text-dim);letter-spacing:0.1em;margin-bottom:24px;}
label{display:block;font-family:'IBM Plex Mono',monospace;font-size:0.6rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold-dim);margin-bottom:6px;}
input[type="text"],input[type="password"],input[type="number"],select,textarea{width:100%;background:rgba(10,22,40,0.8);border:1px solid var(--border);border-radius:2px;padding:10px 13px;color:var(--cream);font-family:'IBM Plex Mono',monospace;font-size:0.86rem;outline:none;transition:border-color 0.2s,box-shadow 0.2s;}
input:focus,select:focus,textarea:focus{border-color:var(--gold);box-shadow:0 0 0 3px rgba(201,168,76,0.1);}
input::placeholder,textarea::placeholder{color:#445566;}
select option{background:var(--navy-mid);}
textarea{resize:vertical;min-height:80px;}
.form-group{margin-bottom:17px;}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;}
.btn{display:inline-block;width:100%;padding:12px;background:linear-gradient(135deg,var(--gold-dim),var(--gold));color:var(--navy);border:none;border-radius:2px;font-family:'IBM Plex Mono',monospace;font-size:0.72rem;letter-spacing:0.2em;text-transform:uppercase;cursor:pointer;font-weight:500;transition:all 0.2s;margin-top:5px;}
.btn:hover{background:linear-gradient(135deg,var(--gold),var(--gold-light));box-shadow:0 4px 20px rgba(201,168,76,0.3);transform:translateY(-1px);}
.btn:active{transform:translateY(0);}
.btn:disabled{opacity:0.45;cursor:not-allowed;transform:none;}
.btn-secondary{background:transparent;border:1px solid var(--border);color:var(--text-dim);margin-top:9px;}
.btn-secondary:hover{background:rgba(201,168,76,0.05);border-color:var(--gold-dim);color:var(--cream);box-shadow:none;}
.btn-red{background:linear-gradient(135deg,#7a1010,var(--red));color:#fff;}
.btn-red:hover{background:linear-gradient(135deg,var(--red),#d04040);}
.btn-green{background:linear-gradient(135deg,#0e4020,var(--green));color:#fff;}
.btn-green:hover{background:linear-gradient(135deg,var(--green),#2a8a4a);}
.error-msg{background:rgba(176,32,32,0.15);border:1px solid rgba(176,32,32,0.4);color:#ff8888;padding:10px 13px;border-radius:2px;font-size:0.72rem;font-family:'IBM Plex Mono',monospace;margin-top:11px;display:none;}
.success-msg{background:rgba(26,107,58,0.15);border:1px solid rgba(26,107,58,0.4);color:#88cc99;padding:10px 13px;border-radius:2px;font-size:0.72rem;font-family:'IBM Plex Mono',monospace;margin-top:11px;display:none;}

/* ═══ SOT DASHBOARD ═══ */
#page-sot-dashboard{background:var(--navy);}
.sot-layout{display:grid;grid-template-columns:210px 1fr;min-height:calc(100vh - 90px);}
.sot-nav{background:rgba(10,22,40,0.5);border-right:1px solid var(--border);padding:16px 0;}
.sot-nav-item{display:flex;align-items:center;gap:9px;padding:10px 18px;cursor:pointer;font-family:'IBM Plex Mono',monospace;font-size:0.68rem;color:#8899aa;letter-spacing:0.04em;transition:all 0.15s;border-left:3px solid transparent;}
.sot-nav-item:hover{color:var(--cream);background:rgba(201,168,76,0.06);}
.sot-nav-item.active{color:var(--gold);background:rgba(201,168,76,0.1);border-left-color:var(--gold);}
.sot-nav-section{font-family:'IBM Plex Mono',monospace;font-size:0.5rem;letter-spacing:0.25em;text-transform:uppercase;color:var(--gold-dim);padding:14px 18px 4px;}
.sot-nav-divider{height:1px;background:var(--border);margin:8px 18px;}
.sot-panel{padding:32px 38px;overflow-y:auto;}
.sot-panel-section{display:none;}
.sot-panel-section.active{display:block;}
.panel-title{font-family:'Playfair Display',serif;font-size:1.35rem;color:var(--gold);margin-bottom:3px;}
.panel-sub{font-family:'IBM Plex Mono',monospace;font-size:0.62rem;color:var(--text-dim);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:24px;}
.stat-cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(170px,1fr));gap:13px;margin-bottom:28px;}
.sc{background:rgba(15,32,64,0.6);border:1px solid var(--border);border-radius:3px;padding:18px 16px;}
.sc .scl{font-family:'IBM Plex Mono',monospace;font-size:0.55rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--text-dim);margin-bottom:7px;}
.sc .scv{font-family:'Playfair Display',serif;font-size:1.45rem;color:var(--gold);}
.sc .scs{font-size:0.75rem;color:#8899aa;margin-top:2px;}
.data-table{width:100%;border-collapse:collapse;font-size:0.8rem;}
.data-table th{font-family:'IBM Plex Mono',monospace;font-size:0.58rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold-dim);text-align:left;padding:9px 13px;border-bottom:1px solid var(--border);}
.data-table td{padding:12px 13px;border-bottom:1px solid rgba(201,168,76,0.06);vertical-align:middle;color:var(--cream);}
.data-table tr:hover td{background:rgba(201,168,76,0.03);}
.mono{font-family:'IBM Plex Mono',monospace;}
.status-badge{font-family:'IBM Plex Mono',monospace;font-size:0.58rem;padding:3px 8px;border-radius:2px;letter-spacing:0.1em;text-transform:uppercase;}
.s-pending{background:rgba(201,168,76,0.15);color:var(--gold);border:1px solid rgba(201,168,76,0.3);}
.s-approved{background:rgba(26,107,58,0.2);color:#66cc88;border:1px solid rgba(26,107,58,0.4);}
.s-denied{background:rgba(176,32,32,0.15);color:#ff8888;border:1px solid rgba(176,32,32,0.3);}
.s-suspended{background:rgba(176,32,32,0.2);color:#ffaaaa;border:1px solid rgba(176,32,32,0.4);}
.s-frozen{background:rgba(0,100,180,0.2);color:#88aaff;border:1px solid rgba(0,100,180,0.4);}
.s-watchlist{background:rgba(180,100,0,0.2);color:#ffaa66;border:1px solid rgba(180,100,0,0.4);}
