  div.innerHTML=`<div class="form-group"><label>Weapon Type</label><select class="wpn-type" onchange="recalcAll()"><option value="">— Select —</option><option>Pistol</option><option>Shotgun</option><option>Rifle</option><option>Sniper</option></select></div>
