  const d=DEPTS.find(x=>x.id===id); if(!d)return;
  d.budget+=grant;
  await savePortalState();
  audit(`Granted ${fmt(grant)} to ${id}. New budget: ${fmt(d.budget)}`,'log-good');
  renderBudgetControl();
};
window.resetBudget = async function(id){
