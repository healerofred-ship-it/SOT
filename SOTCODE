window.submitAccessRequest = async function(){
  const roblox=document.getElementById('entry-roblox').value.trim();
  const discord=document.getElementById('entry-discord').value.trim();
  const dept=document.getElementById('entry-dept').value;
  hideEl('entry-error'); hideEl('entry-success');
  if(!roblox||!discord){showErr('entry-error','Please enter both your Roblox and Discord usernames.');return;}
  const bl=SANCTIONS.find(s=>s.type==='blacklist'&&s.target?.toLowerCase()===roblox.toLowerCase());
  if(bl){showErr('entry-error','Your account has been flagged. Contact an administrator.');return;}
  const existing=REQUESTS.find(r=>r.roblox?.toLowerCase()===roblox.toLowerCase());
  if(existing){
    if(existing.status==='approved'){currentUser={roblox,discord};openUserPortal();return;}
    if(existing.status==='denied'){showErr('entry-error','Your access request was denied by the Secretary of the Treasury.');return;}
    document.getElementById('pending-info').innerHTML=`Roblox: <strong>${roblox}</strong><br>Discord: <strong>${discord}</strong><br>Status: <span style="color:var(--gold)">Awaiting Review</span>`;
    navigate('pending'); return;
  }
  const newReq = {roblox,discord,dept,status:'pending',ts:tsDate(),accessLevel:'standard'};
  const newId = await fbAdd('requests', newReq);
  if(newId) { newReq.id = newId; REQUESTS.unshift(newReq); }
  document.getElementById('pending-info').innerHTML=`Roblox: <strong>${roblox}</strong><br>Discord: <strong>${discord}</strong><br>Dept: <strong>${dept||'Not specified'}</strong><br>Status: <span style="color:var(--gold)">Awaiting Review</span>`;
  navigate('pending');
};

window.sotLogin = function(){
  if(sotLocked){document.getElementById('lockout-msg').style.display='block';return;}
  const user=document.getElementById('sot-user').value.trim();
  const pass=document.getElementById('sot-pass').value;
  document.getElementById('sot-error').style.display='none';
  if(user===SOT_CREDS.user&&pass===SOT_CREDS.pass){
    sotLoginAttempts=0; sotLoggedIn=true;
    document.getElementById('topbar-badge').textContent='Secretary of Treasury';
    document.getElementById('topbar-badge').className='topbar-badge topsec';
    document.getElementById('topbar-badge').style.display='';
    document.getElementById('topbar-logout').style.display='';
    document.getElementById('classif-badge').style.display='block';
    document.getElementById('classif-label').style.display='block';
    audit('Authenticated as Secretary of Treasury','log-good');
    navigate('sot-dashboard');
  } else {
    sotLoginAttempts++;
    audit(`Failed login attempt (${sotLoginAttempts}/3) — user: "${user}"`, 'log-danger');
    if(sotLoginAttempts>=3){
      sotLocked=true;
      document.getElementById('lockout-msg').style.display='block';
      setTimeout(()=>{sotLocked=false;sotLoginAttempts=0;hideEl('lockout-msg');},30000);
    } else {
      document.getElementById('sot-error').style.display='block';
    }
  }
};

