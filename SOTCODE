window.applyMult = async function(cat){
  const inp=document.getElementById('mult_'+cat); if(!inp)return;
  const mult=parseFloat(inp.value)||1; if(mult===1)return;
  if(cat==='heli_per_min') PRICES.heli_per_min=Math.round(PRICES.heli_per_min*mult);
  else if(cat==='subdiv_monthly') PRICES.subdiv_monthly=Math.round(PRICES.subdiv_monthly*mult);
  else if(cat==='weapon') Object.keys(PRICES.weapon).forEach(w=>Object.keys(PRICES.weapon[w]).forEach(t=>{ if(PRICES.weapon[w][t]!==null) PRICES.weapon[w][t]=Math.round(PRICES.weapon[w][t]*mult); }));
  else Object.keys(PRICES[cat]).forEach(k=>{ PRICES[cat][k]=Math.round(PRICES[cat][k]*mult); });
  await savePortalState();
  audit(`Applied ${mult}x multiplier to ${cat}`,'log-warn');
  showSuccess('mult-saved',`${mult}x applied to ${cat}.`);
  renderPriceEditor(); recalcAll();
};

