function fmt(n){
  if(n===null||n===undefined) return '—';
  const neg=n<0; n=Math.abs(n);
  let s;
  if(n>=1e9) s='$'+(n/1e9).toFixed(2).replace(/\.?0+$/,'')+'B';
  else if(n>=1e6) s='$'+(n/1e6).toFixed(3).replace(/\.?0+$/,'')+'M';
  else if(n>=1e3) s='$'+(n/1e3).toFixed(0)+'K';
  else s='$'+n.toLocaleString();
  return neg?'-'+s:s;
}
function ts(){ return new Date().toLocaleTimeString('en-US',{hour:'2-digit',minute:'2-digit',second:'2-digit'}); }
