}
async function fbAdd(col, data){ 
  setSyncing(); 
  try{ const r=await addDoc(collection(db,col),{...data,_ts:serverTimestamp()}); setSynced(); return r.id; }
  catch(e){ setSyncErr(); console.error('fbAdd failed:',col,e); alert('Firebase error (fbAdd): '+e.message); } 
}
async function fbUpdate(path, data){ 
  setSyncing(); 
  try{ await updateDoc(doc(db,...path.split('/')),{...data,_ts:serverTimestamp()}); setSynced(); }
  catch(e){ setSyncErr(); console.error('fbUpdate failed:',path,e); alert('Firebase error (fbUpdate): '+e.message); } 
