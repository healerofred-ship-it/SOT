  audit(`Set ${id} budget: ${fmt(old)} → ${fmt(val)}`,'log-warn');
  renderBudgetControl();
};
window.penalizeBudget = async function(id, mult){
  const d=DEPTS.find(x=>x.id===id); if(!d)return;
  const old=d.budget; d.budget=Math.round(d.budget*mult);
  await savePortalState();
  audit(`Applied ${Math.round((1-mult)*100)}% penalty to ${id}: ${fmt(old)} → ${fmt(d.budget)}`,'log-danger');
  renderBudgetControl();
};
window.grantBudget = async function(id){
  const grant=parseFloat(prompt('Enter grant amount in USD:')||0);
