function getDeptTier(id){ return (DEPTS.find(x=>x.id===id)||{tier:'local'}).tier; }
function getWpnTier(id){ const t=getDeptTier(id); return t==='dot'?'local':t; }

function recalcAll(){
  if(!selectedDeptId)return;
  const dept=DEPTS.find(d=>d.id===selectedDeptId);
  const utier=getDeptTier(selectedDeptId); const wtier=getWpnTier(selectedDeptId);
  const lines=[]; let total=0;
  const utype=document.getElementById('uni-type')?.value; const uqty=parseInt(document.getElementById('uni-qty')?.value)||0;
  if(utype&&uqty>0){ const up=utype==='initial'?PRICES.uniform_initial:PRICES.uniform_monthly; const c=up[utier]*uqty; lines.push({label:`Uniforms (${utype==='initial'?'Initial':'Monthly'}) ×${uqty}`,amt:c}); total+=c; const us=document.getElementById('uni-cost-show'); if(us)us.value=fmt(c); }
  else { const us=document.getElementById('uni-cost-show'); if(us)us.value=''; }
  document.querySelectorAll('.vehicle-entry').forEach(row=>{ const type=row.querySelector('.veh-type').value; const qty=parseInt(row.querySelector('.veh-qty').value)||0; const ct=row.querySelector('.veh-cost-type').value; if(!type||qty<10)return; const p10=ct==='new'?PRICES.vehicle_new[type]:PRICES.vehicle_monthly[type]; const c=p10*Math.floor(qty/10); const lv1=row.querySelector('.liv1').value.trim(); const lv2=row.querySelector('.liv2').value.trim(); let lab=`${type} ×${qty} (${ct==='new'?'new':'maint.'})`; if(lv1)lab+=` · L1:${lv1}`; if(lv2)lab+=` · L2:${lv2}`; lines.push({label:lab,amt:c}); total+=c; row.querySelector('.veh-livery-note').style.display=ct==='new'?'block':'none'; });
  document.querySelectorAll('.weapon-entry').forEach(row=>{ const type=row.querySelector('.wpn-type').value; const qty=parseInt(row.querySelector('.wpn-qty').value)||0; if(!type||qty<=0)return; const tp=PRICES.weapon[type]; const price=tp[wtier]; if(!price){lines.push({label:`${type} ×${qty*100} (unavailable)`,amt:0});return;} const c=price*qty; lines.push({label:`${type}s ×${qty*100}`,amt:c}); total+=c; });
  const hm=parseInt(document.getElementById('heli-mins')?.value)||0; if(hm>0){ const c=hm*PRICES.heli_per_min; lines.push({label:`Helicopter ×${hm} min`,amt:c}); total+=c; }
  const sub=parseInt(document.getElementById('subdiv-qty')?.value)||0; if(sub>0){ const c=sub*PRICES.subdiv_monthly; lines.push({label:`Subdivisions ×${sub}`,amt:c}); total+=c; }
  const cl=document.getElementById('cost-lines-el'); if(cl)cl.innerHTML=!lines.length?'<div style="color:var(--text-dim);font-family:\'IBM Plex Mono\',monospace;font-size:0.74rem;padding:8px 0;">No items selected.</div>':lines.map(l=>`<div class="cost-line"><span class="cll">${l.label}</span><span class="cla">${fmt(l.amt)}</span></div>`).join('');
  const tc=document.getElementById('total-cost-el'); if(tc)tc.textContent=fmt(total);
  const bb=document.getElementById('bal-before-el'); if(bb)bb.textContent=fmt(dept.budget);
  const after=dept.budget-total;
  const ae=document.getElementById('bal-after-el'); if(ae)ae.textContent=after<0?'-'+fmt(Math.abs(after)):fmt(after);
  const ab=document.getElementById('bal-after-box'); if(ab)ab.className='bal-box '+(after>=0?'after-ok':'after-bad');
  const im=document.getElementById('insuf-msg'); if(im)im.style.display=after<0?'block':'none';
  const sb=document.getElementById('submit-order-btn'); if(sb)sb.disabled=after<0;
}
window.recalcAll = recalcAll;

