// ─── EASTER EGGS ───────────────────────────────────────────
document.addEventListener('keydown', e=>{
  konamiSeq.push(e.keyCode); if(konamiSeq.length>10)konamiSeq.shift();
  if(JSON.stringify(konamiSeq)===JSON.stringify(KONAMI)){ triggerKonami(); konamiSeq=[]; }
  secretCode=(secretCode+e.key).slice(-6).toUpperCase();
  if(secretCode==='POTATO'){ triggerPotato(); secretCode=''; }
  _clearSeq=(_clearSeq+e.key).slice(-9).toUpperCase();
  if(_clearSeq==='CLEARDATA'){ if(confirm('WIPE PORTAL STATE? Cannot be undone.')){ fbSet('portal/state',{TAXES:[],PRICES:PRICES,EMERGENCY_STATE:{alert:false,martial:false,budgetFreeze:false,lockdown:false},TICKER_MSG:'',DEPTS:JSON.parse(JSON.stringify(DEFAULT_DEPTS)),DEPT_STATUS:Object.fromEntries(DEFAULT_DEPTS.map(d=>[d.id,'active'])),DEPT_WATCHLIST:Object.fromEntries(DEFAULT_DEPTS.map(d=>[d.id,false]))}); _clearSeq=''; } }
});

function triggerKonami(){
  const flash=document.getElementById('egg-flash'); flash.style.display='block'; flash.style.opacity='0.6';
  setTimeout(()=>{ flash.style.opacity='0'; setTimeout(()=>flash.style.display='none',350); },300);
  document.getElementById('classified-modal').classList.add('open');
  if(sotLoggedIn) audit('Easter egg discovered: Konami Code','log-warn');
}

function triggerPotato(){
  const seal=document.getElementById('seal-btn'); seal.textContent='🥔';
  let deg=0; const spin=setInterval(()=>{ deg+=30; seal.style.transform=`rotate(${deg}deg)`; },50);
  setTimeout(()=>{ clearInterval(spin); seal.textContent='⚖️'; seal.style.transform='';
    const toast=document.createElement('div');
    toast.style.cssText='position:fixed;bottom:30px;right:30px;z-index:9999;background:var(--navy-mid);border:1px solid var(--gold);padding:14px 20px;border-radius:3px;font-family:\'IBM Plex Mono\',monospace;font-size:0.75rem;color:var(--gold);letter-spacing:0.1em;box-shadow:0 10px 30px rgba(0,0,0,0.4);';
    toast.textContent='🥔 Hello, Potato_2305.';
    document.body.appendChild(toast);
    setTimeout(()=>toast.remove(),4000);
    if(sotLoggedIn) audit('Easter egg discovered: POTATO code','log-warn');
  },2000);
}

