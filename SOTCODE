    m.innerHTML=`<div style="font-size:40px;margin-bottom:14px;">⚖️</div><div style="color:var(--gold);font-size:0.75rem;letter-spacing:0.2em;margin-bottom:12px;">SYSTEM MESSAGE</div><div style="color:#aabbcc;font-size:0.8rem;line-height:1.8;">"The strength of a nation's currency<br>reflects the strength of its resolve."<br><br><em style="color:var(--gold-dim);font-size:0.72rem;">— Secretary of the Treasury</em></div><div style="margin-top:18px;font-size:0.62rem;color:#556;">SCRP-TREASURY-INTERNAL-V7 · UPTIME: ${Math.floor(performance.now()/1000)}s</div><button onclick="this.parentNode.remove()" style="margin-top:18px;background:none;border:1px solid var(--gold-dim);color:var(--gold-dim);padding:7px 20px;border-radius:2px;font-family:\'IBM Plex Mono\',monospace;font-size:0.65rem;cursor:pointer;letter-spacing:0.15em;text-transform:uppercase;">Dismiss</button>`;
    document.body.appendChild(m);
